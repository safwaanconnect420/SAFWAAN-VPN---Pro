#------freevpn.us------
#--------------------------
#--------------------------
#--------------------------
client
dev tun
proto udp
remote ovpn-fi-1.vpnv.cc 1194
auth-nocache
resolv-retry infinite
route-method exe
resolv-retry infinite
cipher AES-128-CBC
nobind
persist-key
persist-tun
remote-cert-tls server
auth-user-pass
comp-lzo
verb 3
<ca>
