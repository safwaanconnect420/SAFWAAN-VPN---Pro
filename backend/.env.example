# Server Config
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/safwaan-vpn

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# API Keys
NVIDIA_API_KEY=your_nvidia_api_key_here

# VPN Config Sources
VPN_CONFIG_API=https://raw.githubusercontent.com/mahdibland/V2RayCSV/master/all.csv

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Email (Optional)
